# ============================================
# CHINESE FOOD REELS - Configuration
# ============================================

# Telegram Configuration (for notifications)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=-100xxxxxxxxxx

# Facebook Configuration (for Reels upload)
FB_ACCESS_TOKEN=your_facebook_access_token_here
FB_PAGE_ID=your_facebook_page_id_here

# OpenAI API Key (for Whisper speech detection)
OPENAI_API_KEY=your_openai_api_key_here

# Google Drive (for video source)
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id_here
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
GOOGLE_DRIVE_PHOTO_FOLDER_ID=your_photo_folder_id_here

# YouTube Configuration (for Shorts upload)
YOUTUBE_TOKEN_JSON=your_youtube_token_json_here

# ============================================
# FOOD VIDEO PROCESSING
# ============================================

# Translation: DISABLED (we remove Chinese speech, not translate)
ENABLE_TRANSLATION=false

# Content Source (Chinese video platforms)
# Options: bilibili, douyin, kuaishou
CHINESE_CONTENT_SOURCE=bilibili

# Content Category
# Fixed to: food
CHINESE_CONTENT_CATEGORY=food

# Target Market
CHINESE_TARGET_REGION=united_states

# ============================================
# VIDEO PROCESSING RULES
# ============================================
#
# 1. Video Type: Chinese food videos only
#    - Cooking Process (खाना बनाते हुए)
#    - Food Serving/Plating (खाना सर्व करते हुए)
#    - Food Tasting (खाना टेस्ट करते हुए)
#
# 2. Chinese Language Removal:
#    - All Chinese speech segments are detected via Whisper
#    - Chinese speaking parts are automatically cut out
#    - Only cooking/serving segments are kept
#
# 3. Video Editing:
#    - NO templates, frames, or overlays
#    - Clean fullscreen output
#
# 4. Aspect Ratio:
#    - Final video is always 9:16 (Vertical/Reels/Shorts)
#    - Fits Facebook Reels, Instagram Reels, YouTube Shorts
